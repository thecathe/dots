#!/usr/bin/env bash
# Run from inside any git repo: kp
# Opens a kitty window with one tab per git submodule.
# If no submodules exist, opens a single tab at the project root.

set -euo pipefail

# ── Default editor ────────────────────────────────────────────────────────────
# Set KP_EDITOR=neovide in your shell config to make neovide the default.
# Override per-invocation with --nvim or --neovide.
EDITOR_CMD="${KP_EDITOR:-nvim}"



# ── Flags ─────────────────────────────────────────────────────────────────────
while [[ $# -gt 0 ]]; do
  case "$1" in
    --neovide|-g) EDITOR_CMD="neovide"; shift ;;
    --nvim|-n)    EDITOR_CMD="nvim";    shift ;;
    *)
      echo "usage: kp [--nvim|-n] [--neovide|-g]" >&2
      exit 1
      ;;
  esac
done

# ── Project detection ─────────────────────────────────────────────────────────
PROJECT_ROOT=$(git rev-parse --show-toplevel 2>/dev/null) || {
  echo "error: not inside a git repository" >&2
  exit 1
}

PROJECT_NAME=$(basename "$PROJECT_ROOT")
SUBMODULES=$(git submodule foreach --quiet 'echo $displaypath' 2>/dev/null || echo "")

# ── Launch ────────────────────────────────────────────────────────────────────
if [ "$EDITOR_CMD" = "neovide" ]; then
  # Neovide is a GUI — each repo gets its own window, all detached from kitty.
  # Submodule windows open first, root project opens last.
  while IFS= read -r submodule; do
    [ -z "$submodule" ] && continue
    (cd "$PROJECT_ROOT/$submodule" && KP_PARENT="$PROJECT_NAME" neovide &)
  done <<< "$SUBMODULES"

  cd "$PROJECT_ROOT"
  neovide &
  disown $!

elif [ -n "${KITTY_WINDOW_ID:-}" ]; then
  ORIG_WINDOW=$KITTY_WINDOW_ID

  # open submodules in new tabs
  while IFS= read -r SUBMODULE; do
    [ -z "$SUBMODULE" ] && continue
    kitty @ --to "$KITTY_LISTEN_ON" launch \
      --type=tab \
      --no-response \
      --tab-title "$(basename "$SUBMODULE")" \
      --title "nvim $(basename "$PROJECT_ROOT") $(basename "$SUBMODULE")" \
      --cwd "$PROJECT_ROOT/$SUBMODULE" \
      -- nvim
  done <<< "$SUBMODULES"

  # return focus to original tab and run nvim
  kitty @ --to "$KITTY_LISTEN_ON" focus-window --match "id:$ORIG_WINDOW"
  kitty @ set-tab-title "$(basename "$PROJECT_ROOT")"
  kitty @ set-window-title "nvim $(basename "$PROJECT_ROOT")"
  cd "$PROJECT_ROOT"
  exec nvim
else
  # Outside kitty — open a new window
  {
    echo "new_tab $PROJECT_NAME"
    echo "cd $PROJECT_ROOT"
    echo "launch nvim"

    while IFS= read -r submodule; do
      [ -z "$submodule" ] && continue
      printf "\n"
      echo "new_tab $(basename "$submodule")"
      echo "cd $PROJECT_ROOT/$submodule"
      echo "launch nvim"
    done <<< "$SUBMODULES"
  } | kitty --session -
fi
